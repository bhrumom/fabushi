# Flutter Web Redirects Configuration
# 处理Flutter Web的单页应用路由

# 将所有路由重定向到index.html，让Flutter Router处理
/* /index.html 200

# API请求重定向到后端Worker（如果需要）
/api/* https://fabushi-prod.你的账户名.workers.dev/api/:splat 200

# 静态资源直接服务
/assets/* /assets/:splat 200
/icons/* /icons/:splat 200
/fonts/* /fonts/:splat 200

# 特殊文件直接服务
/favicon.png /favicon.png 200
/manifest.json /manifest.json 200
/flutter_service_worker.js /flutter_service_worker.js 200