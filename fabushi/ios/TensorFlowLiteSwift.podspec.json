{
  "name": "TensorFlowLiteSwift",
  "version": "0.0.1-nightly.20250619",
  "authors": "Google Inc.",
  "license": {
    "type": "Apache"
  },
  "homepage": "https://github.com/tensorflow/tensorflow",
  "source": {
    "http": "https://github.com/tensorflow/tensorflow/archive/d969db94661693f84d7be32a5525045873f429df.zip"
  },
  "summary": "TensorFlow Lite for Swift (Fixed Path for Network Install)",
  "description": "Fixed version of the nightly podspec that accounts for the GitHub archive root directory.",
  "cocoapods_version": ">= 1.9.0",
  "platforms": {
    "ios": "12.0"
  },
  "swift_versions": "5.0",
  "module_name": "TensorFlowLite",
  "static_framework": true,
  "frameworks": [
    "Accelerate",
    "CoreGraphics",
    "CoreVideo",
    "Metal"
  ],
  "pod_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386",
    "ENABLE_USER_SCRIPT_SANDBOXING": "NO"
  },
  "user_target_xcconfig": {
    "EXCLUDED_ARCHS[sdk=iphonesimulator*]": "i386",
    "ENABLE_USER_SCRIPT_SANDBOXING": "NO"
  },
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Privacy",
      "resource_bundles": {
        "TensorFlowLite": "tensorflow-d969db94661693f84d7be32a5525045873f429df/tensorflow/lite/swift/PrivacyInfo.xcprivacy"
      }
    },
    {
      "name": "Core",
      "dependencies": {
        "TensorFlowLiteC": [
          "0.0.1-nightly.20250619"
        ],
        "TensorFlowLiteSwift/Privacy": [
          "0.0.1-nightly.20250619"
        ]
      },
      "source_files": "tensorflow-d969db94661693f84d7be32a5525045873f429df/tensorflow/lite/swift/Sources/*.swift",
      "exclude_files": "tensorflow-d969db94661693f84d7be32a5525045873f429df/tensorflow/lite/swift/Sources/{CoreML,Metal}Delegate.swift"
    }
  ],
  "swift_version": "5.0"
}
