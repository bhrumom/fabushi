// Service Worker 后台发送服务 - v14.0 (支持锁屏通知栏实时更新)

let isRunning = false;
let loopMode = false;
let contentQueue = [];
let countryServers = {};
let countryNames = {};
let loopDelay = 15000;
let sendConcurrency = 5; // 默认并发数为5
let abortController;
let downloadManager = null; // 断点续传下载器
let uploadProgressCacheName = 'upload-progress-v1';
let enableChunkUpload = false; // 默认为关闭，避免与不支持分片的服务器不兼容
// 新增：发送中断修复相关变量
let isPaused = false;
let lastHeartbeat = Date.now();
let activeUploads = new Map();
let memoryWarningThreshold = 400 * 1024 * 1024; // 400MB
let taskProgressMap = new Map(); // 任务进度跟踪
// activeUploads 机制已被更高效的 Worker Pool 模式取代

// 通知栏实时更新相关变量
let notificationPermission = 'default';
let currentNotification = null;
let notificationUpdateTimer = null;
let sendingStartTime = 0;
let totalFilesToSend = 0;
let filesCompleted = 0;
let currentFileName = '';
let lastNotificationUpdate = 0;
const NOTIFICATION_UPDATE_INTERVAL = 2000; // 2秒更新一次通知

// 全局错误处理
self.addEventListener('error', (event) => {
    logMessage(`❌ 全局错误: ${event.error?.message || event.message}`);
    console.error('Service Worker 全局错误:', event.error);
});

self.addEventListener('unhandledrejection', (event) => {
    logMessage(`❌ 未处理的 Promise 拒绝: ${event.reason?.message || event.reason}`);
    console.error('Service Worker 未处理的 Promise 拒绝:', event.reason);
    // 防止错误传播导致 Service Worker 崩溃
    event.preventDefault();
});

/**
 * 初始化通知权限
 */
async function initNotificationPermission() {
    if (!('Notification' in self)) {
        logMessage('⚠️ 此浏览器不支持通知功能');
        return;
    }

    try {
        notificationPermission = await self.registration.showNotification.permission || 'default';
        
        if (notificationPermission === 'default') {
            // 在 Service Worker 中不能直接请求权限，需要通过主线程
            logMessage('🔔 需要用户授权通知权限，请在主页面中点击允许');
            postMessageToClients({
                type: 'requestNotificationPermission',
                payload: {}
            });
        } else if (notificationPermission === 'granted') {
            logMessage('✅ 通知权限已获取');
        } else {
            logMessage('❌ 通知权限被拒绝，无法显示锁屏通知');
        }
    } catch (error) {
        logMessage(`⚠️ 初始化通知权限失败: ${error.message}`);
    }
}

/**
 * 创建或更新发送进度通知
 */
async function showOrUpdateProgressNotification(options = {}) {
    if (notificationPermission !== 'granted') {
        return;
    }

    try {
        const {
            title = '📾 全球法布施发送中...',
            body,
            progress = 0,
            fileName = '',
            completedFiles = 0,
            totalFiles = 0,
            tag = 'dharma-sending-progress'
        } = options;

        // 构建通知内容
        let notificationBody;
        if (fileName) {
            const fileProgress = totalFiles > 0 ? `(${completedFiles + 1}/${totalFiles})` : '';
            notificationBody = `正在发送: ${fileName} ${fileProgress}\n进度: ${progress.toFixed(1)}%`;
        } else {
            notificationBody = body || `进度: ${progress.toFixed(1)}%`;
        }

        // 关闭之前的通知
        if (currentNotification) {
            currentNotification.close();
        }

        // 显示新通知
        currentNotification = await self.registration.showNotification(title, {
            body: notificationBody,
            icon: '/favicon.ico', // 使用网站图标
            badge: '/favicon.ico',
            tag: tag,
            requireInteraction: false, // 设为 false 让通知自动消失
            silent: true, // 静默通知，不发声
            renotify: true, // 允许更新相同 tag 的通知
            data: {
                type: 'progress',
                progress: progress,
                fileName: fileName,
                timestamp: Date.now()
            },
            actions: [
                {
                    action: 'view',
                    title: '👁️ 查看进度',
                    icon: '/favicon.ico'
                },
                {
                    action: 'stop',
                    title: '⏹️ 停止发送',
                    icon: '/favicon.ico'
                }
            ]
        });

        // 优化：移除频繁的通知更新日志，减少噪音
        // logMessage(`🔔 进度通知已更新: ${progress.toFixed(1)}% - ${fileName}`);
    } catch (error) {
        logMessage(`⚠️ 更新进度通知失败: ${error.message}`);
    }
}

/**
 * 显示发送完成通知
 */
async function showCompletionNotification(options = {}) {
    if (notificationPermission !== 'granted') {
        return;
    }

    try {
        const {
            success = true,
            totalFiles = 0,
            totalTime = 0,
            isLoopMode = false
        } = options;

        // 关闭进度通知
        if (currentNotification) {
            currentNotification.close();
            currentNotification = null;
        }

        const title = success ? '✅ 发送完成' : '❌ 发送中断';
        const timeStr = totalTime > 0 ? `耗时: ${Math.floor(totalTime / 1000)}秒` : '';
        const loopStr = isLoopMode ? '\n循环模式将继续...' : '';
        const body = `共处理 ${totalFiles} 个文件${timeStr ? '\n' + timeStr : ''}${loopStr}`;

        await self.registration.showNotification(title, {
            body: body,
            icon: '/favicon.ico',
            badge: '/favicon.ico',
            tag: 'dharma-sending-complete',
            requireInteraction: true, // 完成通知需要用户交互
            data: {
                type: 'complete',
                success: success,
                timestamp: Date.now()
            },
            actions: [
                {
                    action: 'view',
                    title: '👁️ 查看详情',
                    icon: '/favicon.ico'
                }
            ]
        });

        // 优化：只在完成时显示通知日志，减少频繁输出
        // logMessage(`🔔 发送完成通知已显示`);
    } catch (error) {
        logMessage(`⚠️ 显示完成通知失败: ${error.message}`);
    }
}

/**
 * 定时更新进度通知
 */
function scheduleNotificationUpdate() {
    if (notificationUpdateTimer) {
        clearInterval(notificationUpdateTimer);
    }

    if (!isRunning || notificationPermission !== 'granted') {
        return;
    }

    notificationUpdateTimer = setInterval(() => {
        if (!isRunning) {
            clearInterval(notificationUpdateTimer);
            return;
        }

        const now = Date.now();
        if (now - lastNotificationUpdate < NOTIFICATION_UPDATE_INTERVAL) {
            return;
        }

        // 计算当前进度
