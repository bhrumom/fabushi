// 所有发送任务现在由 Web Worker 和现代 Fetch API 处理

let isRunning = false;
let contentQueue = [];
let countryServers = {};
let countryNames = {};
let loopMode = false;
let loopDelay = 15000;

// 全局错误处理
self.addEventListener('error', (event) => {
    console.error('Service Worker 全局错误:', event.error);
});

self.addEventListener('unhandledrejection', (event) => {
    console.error('Service Worker 未处理的 Promise 拒绝:', event.reason);
    event.preventDefault();
});

/**
 * 发送日志消息
 */
function logMessage(message, priority = 'normal') {
    try {
        const timestamp = new Date().toLocaleTimeString();
        const fullMessage = `[${timestamp}] [SW] ${message}`;
        
        // 只输出错误、警告和重要信息
        const isErrorMessage = message.includes('❌') || message.includes('失败') || 
                              message.includes('错误') || message.includes('超时') ||
                              message.includes('异常') || priority === 'error';
        
        const isWarningMessage = message.includes('⚠️') || message.includes('警告') ||
                               priority === 'warning';
        
        const isImportantMessage = message.includes('🚀') || message.includes('⏹️') ||
                                 message.includes('启动') || message.includes('停止') ||
                                 priority === 'important';
        
        // 只在控制台输出错误、警告和重要信息
        if (isErrorMessage || isWarningMessage || isImportantMessage) {
            console.log(fullMessage);
        }
        
    } catch (error) {
        console.error('logMessage 错误:', error);
    }
}

async function postMessageToClients(messageObject) {
    try {
        const clients = await self.clients.matchAll({ includeUncontrolled: true, type: 'window' });
        clients.forEach(client => {
            try {
                client.postMessage(messageObject);
            } catch (error) {
                console.error('发送消息到客户端失败:', error);
            }
        });
    } catch (error) {
        console.error('获取客户端列表失败:', error);
    }
}

// Service Worker 事件监听
self.addEventListener('install', (event) => {
    logMessage('Service Worker 安装中...');
    event.waitUntil(self.skipWaiting());
});

self.addEventListener('activate', (event) => {
    logMessage('Service Worker 已激活!');
    event.waitUntil(self.clients.claim());
});

self.addEventListener('message', (event) => {
    const { command, payload } = event.data;

    switch (command) {
        case 'start':
            logMessage('⚠️ Service Worker 不再处理发送任务，请使用页面中的 Web Worker 发送');
            // 通知页面使用 Web Worker 发送
            postMessageToClients({
                type: 'use-web-worker',
                message: '请使用页面中的 Web Worker 发送功能'
            });
            break;

        case 'stop':
            logMessage('⏹️ 收到停止指令');
            isRunning = false;
            postMessageToClients({ type: 'stopped' });
            break;
    }
});

self.addEventListener('fetch', (event) => {
    // 如果请求的不是 favicon.ico，则提前返回，让浏览器正常处理网络请求。
    if (!event.request.url.includes('favicon.ico')) {
        return;
    }

    // 按原样处理 favicon.ico 请求。
    event.respondWith(
        new Response(null, {
            status: 204,
            statusText: 'No Content'
        })
    );
});

/**
 * 小文件快速发送函数 - 根本问题修复版
 * 解决Promise死锁、超时悬挂、FormData重用等根本原因
 */
async function sendSmallFileFast(item, fileBlob, allCountryCodes) {
    logMessage(`🚀 小文件快速通道启动: ${item.name}`);
    
    let successCount = 0;
    let failureCount = 0;
    
    try {
        logMessage(`📦 小文件逐个处理 ${allCountryCodes.length} 个国家，避免Promise死锁`);
        
        // [根本修复] 逐个处理，彻底避免Promise.allSettled死锁问题
        for (let i = 0; i < allCountryCodes.length; i++) {
            if (!isRunning) break;
            
            const countryCode = allCountryCodes[i];
            const servers = countryServers[countryCode];
            
            if (!servers || servers.length === 0) {
                logMessage(`⚠️ ${countryCode} 无可用服务器`);
                continue;
            }
            
            const serverUrl = servers[0];
            const countryName = countryNames[countryCode] || countryCode;
            
            // [根本修复] 每个请求单独创建FormData，避免重用冲突
            const formData = new FormData();
            formData.append('file', fileBlob, item.name);
            
            postMessageToClients({
                type: 'countryStatus',
                payload: {
                    countryCode: countryCode,
                    status: 'sending',
                    fileName: item.name
                }
            });
            
            let countrySuccess = false;
            
            // [根本修复] 简化重试逻辑，避免Promise嵌套死锁
            for (let retry = 0; retry < 3; retry++) {
                if (!isRunning) break;
                
                try {
                    // [根本修复] 使用fetchWithFallback的绝对超时机制，不再双重包装
                    await fetchWithFallback(serverUrl, {
                        method: 'POST',
                        body: formData,
                        timeout: 15000 // 小文件15秒超时
                    });
                    
                    countrySuccess = true;
                    break;
                    
                } catch (error) {
                    logMessage(`⚠️ ${countryName} 第${retry + 1}次尝试失败: ${error.message}`);
                    
                    // 简单延迟，避免复杂Promise
                    if (retry < 2) {
                        await new Promise(resolve => setTimeout(resolve, 1000 * (retry + 1)));
                    }
                }
            }
            
            if (countrySuccess) {
                successCount++;
                // 优化：成功发送只记录到国家状态，不输出控制台
                postMessageToClients({
                    type: 'countryComplete',
                    payload: {
                        countryCode: countryCode,
                        fileName: item.name,
                        success: true
                    }
                });
                // 不再输出成功信息到控制台，减少日志噪音
            } else {
                failureCount++;
                // 优化：只输出失败信息到控制台
                logMessage(`❌ ${countryName} 发送失败: 重试后仍失败`);
                postMessageToClients({
                    type: 'countryComplete',
                    payload: {
                        countryCode: countryCode,
                        fileName: item.name,
                        success: false,
                        error: '重试后仍失败'
                    }
                });
            }
            
            // 简短延迟，避免网络拥塞
            if (i < allCountryCodes.length - 1 && isRunning) {
                await new Promise(resolve => setTimeout(resolve, 50));
            }
            
            // 优化：移除所有进度日志输出，只在出现错误时输出
            // if ((i + 1) % 25 === 0) { // 每25个国家输出一次
            //     logMessage(`📊 小文件进度: ${i + 1}/${allCountryCodes.length} (成功: ${successCount}, 失败: ${failureCount})`, 'important');
            // }
        }
        
        // 优化：摘要信息简化，只输出关键数据
        logMessage(`🎯 小文件处理完成: ${item.name} - 成功率: ${(successCount/allCountryCodes.length*100).toFixed(1)}% (${successCount}/${allCountryCodes.length})`, 'important');
        return successCount;
        
    } catch (error) {
        logMessage(`❌ 小文件快速通道异常: ${item.name} - ${error.message}`);
        return successCount;
    }
}

/**
 * [内存优化] 使用 Worker Pool 模式将文件发送到所有国家。
 * 此方法创建固定数量的 "worker" (并发的 async 函数)，
 * 每个 worker 从队列中取出一个国家进行处理，直到队列为空。
 * 这避免了一次性为所有国家创建 Promise，从而显著降低内存峰值和卡顿。
 */
async function sendToAllCountries(item) {
    const allCountryCodes = Object.keys(countryServers);
    logMessage(`🚀 开始向 ${allCountryCodes.length} 个国家分派发送任务: ${item.name}`);

    let fileBlob;
    try {
        if (item.type === 'file') {
            fileBlob = item.file;
        } else {
            fileBlob = await downloadAssetContent(item);
            if (!fileBlob) {
                logMessage(`❌ 无法获取素材 "${item.name}" 的内容，跳过此文件`);
                return 0; // 返回已分派的数量
            }
        }
    } catch (error) {
        logMessage(`❌ 获取文件内容时出错: ${error.message}`);
        return 0;
    }

    // 小文件快速通道 - 直接发送，跳过复杂处理
    const fileSizeMB = fileBlob.size / (1024 * 1024);
    if (fileSizeMB <= 1) {
        logMessage(`🚀 小文件快速通道: ${item.name}`);
        return await sendSmallFileFast(item, fileBlob, allCountryCodes);
    }

    // 根据文件大小动态调整并发数
    let dynamicConcurrency = sendConcurrency;
    
    if (fileSizeMB > 500) {
        dynamicConcurrency = Math.max(1, Math.floor(sendConcurrency / 4)); // 超大文件：并发数/4
        logMessage(`📊 超大文件 (${fileSizeMB.toFixed(1)}MB)，降低并发数至: ${dynamicConcurrency}`);
    } else if (fileSizeMB > 100) {
        dynamicConcurrency = Math.max(2, Math.floor(sendConcurrency / 2)); // 大文件：并发数/2
        logMessage(`📊 大文件 (${fileSizeMB.toFixed(1)}MB)，降低并发数至: ${dynamicConcurrency}`);
    } else if (fileSizeMB <= 1) {
        dynamicConcurrency = Math.min(sendConcurrency, 3); // 小文件限制并发，避免网络拥塞
        logMessage(`📊 小文件 (${fileSizeMB.toFixed(1)}MB)，限制并发数至: ${dynamicConcurrency}`);
    }

    const countryQueue = [...allCountryCodes]; // 创建一个可变的国家队列
    let dispatchCount = 0;
    let successCount = 0;
    let failureCount = 0;

    // [根本修复] 优化的 worker 任务 - 添加超时保护，防止卡死
    const worker = async () => {
        let processedInThisWorker = 0;
        
        while (countryQueue.length > 0 && isRunning) {
            let countryCode;

            // 原子操作：安全地从队列中取出国家代码
            try {
                countryCode = countryQueue.shift();
                if (!countryCode) break;
            } catch (error) {
                console.error(`队列操作错误: ${error.message}`);
                break;
            }

            const servers = countryServers[countryCode] || [];
            if (servers.length === 0) {
                console.warn(`国家 ${countryCode} 无可用服务器`);
                continue;
            }

            const serverUrl = servers[0];
            const countryName = countryNames[countryCode] || countryCode;
            dispatchCount++;

            try {
                if (!isRunning) break;

                // 发送国家开始处理状态
                postMessageToClients({
                    type: 'countryStatus',
                    payload: {
                        countryCode: countryCode,
                        status: 'sending',
                        fileName: item.name
                    }
                });

                // [根本修复] 为上传文件添加超时保护，防止无限等待
                const uploadPromise = uploadFileWithAutoChunking({ 
                    serverUrl, 
                    fileBlob, 
                    fileName: item.name, 
                    countryName, 
                    countryCode 
                });
                
                // 为每个国家的上传设置超时：根据文件大小动态调整
                let uploadTimeout = 30000; // 默认30秒
                if (fileSizeMB > 100) {
                    uploadTimeout = 300000; // 大文件：5分钟
                } else if (fileSizeMB > 10) {
                    uploadTimeout = 120000; // 中等文件：2分钟
                } else if (fileSizeMB > 1) {
                    uploadTimeout = 60000;  // 小文件：1分钟
                }
                
                const timeoutPromise = new Promise((_, reject) => {
                    setTimeout(() => reject(new Error(`国家 ${countryName} 上传超时 (${uploadTimeout/1000}秒)`)), uploadTimeout);
                });
                
                // 使用Promise.race确保必定返回
                await Promise.race([uploadPromise, timeoutPromise]);

                successCount++;
                processedInThisWorker++;

                // 发送国家完成状态
                postMessageToClients({
                    type: 'countryComplete',
                    payload: {
                        countryCode: countryCode,
                        fileName: item.name,
                        success: true
                    }
                });
                
                // 发送实时进度更新
                // if (processedInThisWorker % 5 === 0 || successCount % 10 === 0) {
                //     postMessageToClients({
                //         type: 'workerProgress',
                //         payload: {
                //             fileName: item.name,
                //             processedCountries: successCount + failureCount,
                //             totalCountries: allCountryCodes.length,
                //             successCount: successCount,
                //             failureCount: failureCount
                //         }
                //     });
                // }
                
                // 优化：移除所有进度日志输出，只在出现错误时输出
                // if (processedInThisWorker % 20 === 0) { // 每20个国家输出一次
                //     logMessage(`📊 Worker进度: 已处理 ${processedInThisWorker} 个国家 (成功: ${successCount}, 失败: ${failureCount})`, 'important');
                // }
                
            } catch (error) {
                failureCount++;
                
                // 发送国家失败状态
                postMessageToClients({
                    type: 'countryComplete',
                    payload: {
                        countryCode: countryCode,
                        fileName: item.name,
                        success: false,
                        error: error.message
                    }
                });
                
                if (error.name === 'AbortError') {
                    // console.log(`发送被中止: ${countryName}`);
                    break;
                } else {
                    console.error(`发送失败 ${countryName}: ${error.message}`);
                    // [根本修复] 记录失败原因，但继续处理其他国家
                    logMessage(`❌ 国家 ${countryName} 处理失败: ${error.message}`);
                }
            }

            // 根据文件大小调整延迟时间
            if (countryQueue.length > 0 && isRunning) {
                let workerDelay = 25; // 默认25ms
                if (fileSizeMB > 500) {
                    workerDelay = 2000; // 超大文件：2秒间隔
                } else if (fileSizeMB > 100) {
                    workerDelay = 1000; // 大文件：1秒间隔
                } else if (fileSizeMB > 50) {
                    workerDelay = 500;  // 中等文件：0.5秒间隔
                }
                await new Promise(resolve => setTimeout(resolve, workerDelay));
            }
        }
        
        return processedInThisWorker;
    };

    // [根本修复] 创建并启动 worker pool，添加整体超时保护
    const workerPool = [];
    for (let i = 0; i < dynamicConcurrency; i++) {
        workerPool.push(worker().catch(error => {
            logMessage(`❌ Worker ${i + 1} 出现错误: ${error.message}`);
            // 不重新抛出错误，让其他 worker 继续工作
            return null;
        }));
    }

    // [根本修复] 为Worker Pool添加整体超时保护，防止整个文件卡死
    const workerPoolTimeout = Math.max(300000, allCountryCodes.length * 10000); // 最少5分钟，或每个国家10秒
    const workerPoolTimeoutPromise = new Promise((_, reject) => {
        setTimeout(() => {
            reject(new Error(`Worker Pool 整体超时 (${workerPoolTimeout/1000}秒)，可能存在网络问题`));
        }, workerPoolTimeout);
    });

    // 等待所有 worker 完成它们的工作，但有整体超时保护
    try {
        await Promise.race([
            Promise.all(workerPool),
            workerPoolTimeoutPromise
        ]);
    } catch (error) {
        if (error.message.includes('整体超时')) {
            logMessage(`⚠️ Worker Pool 整体超时，可能网络环境存在问题，强制继续...`, 'important');
            // 超时不抛出错误，让系统继续运行
        } else {
            logMessage(`❌ Worker pool 执行出错: ${error.message}`);
        }
        // 即使有错误也继续执行，确保不会完全停止
    }

    if (!isRunning) {
        logMessage(`🚁 发送任务在处理文件 "${item.name}" 期间被中止。已处理: ${dispatchCount}, 成功: ${successCount}, 失败: ${failureCount}`);
    } else {
        logMessage(`🚁 文件 "${item.name}" 的所有国家均已处理完毕 (并发: ${dynamicConcurrency}, 已处理: ${dispatchCount}, 成功: ${successCount}, 失败: ${failureCount})`);
    }

    // 如果剩余队列不为空，说明可能有问题
    if (countryQueue.length > 0) {
        logMessage(`⚠️ 注意: 还有 ${countryQueue.length} 个国家未处理: ${countryQueue.slice(0, 5).join(', ')}${countryQueue.length > 5 ? '...' : ''}`);
    }

    return dispatchCount; // 返回实际处理的国家数量
}


/**
 * [内存优化] 启动发送流程。
 * 该版本使用 Worker Pool 模式，并且 sendToAllCountries 会等待其文件处理完成后再继续，
 * 从而简化了循环逻辑。
 */
async function startSendingProcess() {
    if (isRunning) {
        // console.log("⚠️ 发送任务已在运行中");
        return;
    }

    isRunning = true;
    abortController = new AbortController();
    const allCountryCodes = Object.keys(countryServers);
    const totalFiles = contentQueue.length;
    let completedFiles = 0;
    let totalDispatches = 0;
    let cycleCount = 0;
    let lastProgressTime = Date.now();

    // 初始化通知相关变量
    sendingStartTime = Date.now();
    totalFilesToSend = totalFiles;
    filesCompleted = 0;
    currentFileName = '';
    
    // 初始化通知权限和显示开始通知
    await initNotificationPermission();
    if (notificationPermission === 'granted') {
        await showOrUpdateProgressNotification({
            title: '🌍 全球法布施启动',
            body: `准备发送 ${totalFiles} 个文件到 ${allCountryCodes.length} 个国家`,
            progress: 0
        });
    }

    // console.log(`🚀 发送服务已启动 (并发数: ${sendConcurrency})，文件数: ${totalFiles}，目标国家: ${allCountryCodes.length}`);
    if (loopMode) {
        // console.log(`☸️ 循环模式已启用`);
    }

    // [关键修复] 只发送关键事件，不发送日志
    postMessageToClients({
        type: 'started',
        payload: {
            startTime: Date.now(),
            totalFiles: totalFiles,
            totalCountries: allCountryCodes.length,
            isLoopMode: loopMode
        }
    });

    // 启动定时通知更新
    scheduleNotificationUpdate();

    // 禁用进度监控，避免干扰循环延迟
    // console.log('ℹ️ 进度监控已禁用，专注于循环延迟测试');

    /*
    // 进度监控代码已暂时禁用
    let stallCheckCount = 0;
    const progressMonitor = setInterval(() => {
        // ... 监控逻辑
    }, 30000);
    */

    try {
        do {
            cycleCount++;
            if (loopMode) {
                // console.log(`🔄 开始第 ${cycleCount} 轮循环`);
            }

            // 文件处理是串行的
            for (let i = 0; i < contentQueue.length; i++) {
                if (!isRunning) break;

                const item = contentQueue[i];
                // console.log(`📥 [${i + 1}/${totalFiles}] 开始处理文件: ${JSON.stringify(item)}`);
                
                // 更新当前文件名和文件计数
                currentFileName = item.name;
                filesCompleted = i;

                // 更新通知进度
                if (notificationPermission === 'granted') {
                    const overallProgress = totalFilesToSend > 0 ? ((i / totalFilesToSend) * 100) : 0;
                    await showOrUpdateProgressNotification({
                        progress: overallProgress,
                        fileName: item.name,
                        completedFiles: i,
                        totalFiles: totalFilesToSend
                    });
                }

                try {
            // [关键修复] 发送文件处理开始通知，不依赖日志系统
                    postMessageToClients({
                        type: 'fileProcessingStart',
                        payload: {
                            fileName: item.name,
                            fileIndex: i,
                            totalFiles: totalFiles
                        }
                    });

                    const startTime = Date.now();
                    
                    // sendToAllCountries 现在会阻塞，直到该文件的所有国家都处理完毕
                    const dispatchCount = await sendToAllCountries(item);

                    const endTime = Date.now();
                    const duration = endTime - startTime;

                    completedFiles++;
                    filesCompleted = completedFiles;
                    totalDispatches += dispatchCount;

                    // 更新文件完成后的通知进度
                    if (notificationPermission === 'granted') {
                        const overallProgress = totalFilesToSend > 0 ? ((completedFiles / totalFilesToSend) * 100) : 100;
                        await showOrUpdateProgressNotification({
                            progress: overallProgress,
                            fileName: `✅ ${item.name} 已完成`,
                            completedFiles: completedFiles,
                            totalFiles: totalFilesToSend
                        });
                    }

                    // [关键修复] 发送文件处理完成通知，不依赖日志系统
                    postMessageToClients({
                        type: 'fileProcessingComplete',
                        payload: {
                            fileName: item.name,
                            successCount: dispatchCount,
                            totalCountries: allCountryCodes.length,
                            duration: duration
                        }
                    });

                    const progressPayload = {
                        completedFiles,
                        totalFiles: totalFiles,
                        currentFile: item.name,
                        dispatchedInThisFile: dispatchCount,
                        totalDispatches: totalDispatches,
                        totalCountries: allCountryCodes.length,
                        cycle: cycleCount,
                        isLoopMode: loopMode
                    };

                    lastProgressTime = Date.now(); // 更新进度时间
                    
                    // [关键修复] 直接发送进度更新，不经过日志系统
                    postMessageToClients({ type: 'progress', payload: progressPayload });

                } catch (error) {
                    console.error(`处理文件 "${item.name}" 时发生严重错误: ${error.message}`);
                    completedFiles++; // 即使出错也标记为已处理，以继续
                    filesCompleted = completedFiles;
                    const errorPayload = {
                        completedFiles,
                        totalFiles: totalFiles,
                        hasError: true
                    };
                    postMessageToClients({ type: 'progress', payload: errorPayload });
                }

                if (!isRunning) break;

                // 文件处理之间短暂延迟
                if (i < contentQueue.length - 1) {
                    await new Promise(resolve => setTimeout(resolve, 500));
                }
            }

            // 由于 sendToAllCountries 现在是阻塞的，不再需要复杂的 activeUploads 等待逻辑。
            // 当代码执行到这里时，当前循环的所有文件都已处理完毕。
            if (isRunning) {
                // console.log(`✅ [Cycle ${cycleCount}] 本轮所有文件处理完成。`);
            }

            if (loopMode && isRunning) {
                // 发送循环完成事件
                postMessageToClients({
                    type: 'cycleComplete',
                    payload: {
                        cycle: cycleCount,
                        completedFiles: completedFiles,
                        totalDispatches: totalDispatches,
                        nextCycleIn: loopDelay / 1000
                    }
                });

                completedFiles = 0;
                filesCompleted = 0; // 重置文件计数
                totalDispatches = 0;
                
                // 循环模式通知更新
                if (notificationPermission === 'granted') {
                    await showOrUpdateProgressNotification({
                        title: '🔄 循环发送中...',
                        body: `第 ${cycleCount} 轮已完成，${loopDelay / 1000}秒后开始下一轮`,
                        progress: 0,
                        fileName: '准备下一轮循环...',
                        completedFiles: 0,
                        totalFiles: totalFilesToSend
                    });
                }
                
                logMessage(`✅ 第 ${cycleCount} 轮完成，${loopDelay / 1000}秒后开始下一轮...`, 'important');

                // 新增：在每轮循环后进行内存清理，防止资源泄露
                logMessage('🧹 正在执行循环后内存清理...', 'important');
                await handleMemoryCleanup();
                logMessage('✅ 内存清理完成。');

                // [根本修复] 简化循环延迟机制，避免复杂的分步检查
                logMessage(`⏳ 开始循环延迟 ${loopDelay / 1000} 秒...`, 'important');

                try {
                    // [增强修复] 使用可中断的循环延迟机制，添加进度报告
                    logMessage(`⏳ 开始循环延迟 ${loopDelay / 1000} 秒，将定时报告进度...`, 'important');
                    
                    // 添加循环延迟进度报告
                    const delayStartTime = Date.now();
                    let delayReported = false;
                    
                    await new Promise((resolve, reject) => {
                        if (!isRunning || !loopMode) {
                            resolve();
                            return;
                        }
                        
                        let resolved = false;
                        const safeResolve = () => {
                            if (!resolved) {
                                resolved = true;
                                resolve();
                            }
                        };
                        
                        // 主要延迟定时器
                        const timeoutId = setTimeout(() => {
                            safeResolve();
                        }, loopDelay);
                        
                        // 状态检查和进度报告（每秒）
                        const checkInterval = setInterval(() => {
                            if (!isRunning || !loopMode || (abortController && abortController.signal.aborted)) {
                                clearTimeout(timeoutId);
                                clearInterval(checkInterval);
                                safeResolve();
                                return;
                            }
                            
                            // 报告延迟进度
                            const elapsed = Date.now() - delayStartTime;
                            const progress = Math.min((elapsed / loopDelay) * 100, 100);
                            if (progress >= 25 && !delayReported) {
                                // console.log(`[${new Date().toLocaleTimeString()}] [SW] ⏳ 循环延迟进度: ${progress.toFixed(1)}% (${Math.floor(elapsed/1000)}/${Math.floor(loopDelay/1000)}秒)`);
                                delayReported = true;
                            }
                        }, 1000);
                        
                        // 安全清理定时器（防止内存泄漏）
                        const cleanupTimeout = setTimeout(() => {
                            clearTimeout(timeoutId);
                            clearInterval(checkInterval);
                            if (!resolved) {
                                // console.log('⚠️ 循环延迟安全清理触发');
                                safeResolve();
                            }
                        }, loopDelay + 2000);
                    });
                    
                    // console.log(`[${new Date().toLocaleTimeString()}] [SW] ✅ 循环延迟完成，开始第 ${cycleCount + 1} 轮`);
                    
                } catch (delayError) {
                    console.error(`❌ 循环延迟过程中出现异常: ${delayError.message}`);
                    // 即使延迟出错也继续循环，不中断整个系统
                    // console.log('⚠️ 尝试继续循环...');
                }
            }

        } while (loopMode && isRunning);

    } catch (error) {
        if (error.name !== 'AbortError') {
            logMessage(`❌ 发送主流程出错: ${error.message}`);
        }
    } finally {
        // 清理进度监控
        if (typeof progressMonitor !== 'undefined') {
            clearInterval(progressMonitor);
            logMessage('🧹 进度监控已清理');
        }

        // 停止通知更新
        stopNotificationUpdates();
        
        // 显示完成通知
        if (notificationPermission === 'granted') {
            const totalTime = Date.now() - sendingStartTime;
            await showCompletionNotification({
                success: isRunning, // 如果 isRunning 为 true 表示正常完成，否则是中断
                totalFiles: totalFilesToSend,
                totalTime: totalTime,
                isLoopMode: loopMode
            });
        }

        // 最终内存清理
        try {
            await handleMemoryCleanup();
            logMessage('🧹 最终内存清理完成');
        } catch (error) {
            logMessage(`⚠️ 最终内存清理失败: ${error.message}`);
        }

        if (isRunning) {
            logMessage(loopMode ? '⏹️ 循环分派已停止' : '✅ 所有文件发送任务已完成');
            postMessageToClients({ type: 'finished', payload: { completedFiles, totalDispatches } });
        }
        isRunning = false;
        logMessage('📊 发送流程最终状态: 已停止');
    }
}

/**
 * 将文件以分片或单请求方式发送。
 * 此函数会等待上传完成后再返回，以确保 activeUploads 计数器准确。
 */
async function uploadFileWithAutoChunking({ serverUrl, fileBlob, fileName, countryName, countryCode }) {
    if (!fileBlob) throw new Error('缺少文件内容');
    if (!isRunning) throw new Error('服务已停止');

    const fileSizeMB = fileBlob.size / (1024 * 1024);
    const chunkThreshold = 50; // 50MB以上启用分片上传

    try {
        // 发送上传开始通知
        postMessageToClients({
            type: 'uploadProgress',
            payload: {
                fileName: fileName,
                countryName: countryName,
                uploaded: 0,
                total: fileBlob.size,
                progress: 0
            }
        });

        // 大文件使用分片上传，小文件直接上传
        if (enableChunkUpload && fileSizeMB > chunkThreshold) {
            logMessage(`📦 大文件分片上传: ${fileName} (${fileSizeMB.toFixed(1)}MB) -> ${countryName}`, 'important');
            const fileId = await computeUploadId(fileBlob, fileName);
            // 根据文件大小动态调整分片大小
            let chunkSize;
            if (fileSizeMB > 500) {
                // 超大文件(>500MB): 使用2-5MB分片，确保网络稳定性
                chunkSize = Math.max(2 * 1024 * 1024, Math.min(5 * 1024 * 1024, fileBlob.size / 50));
                logMessage(`📦 超大文件使用小分片: ${(chunkSize / 1024 / 1024).toFixed(1)}MB`);
            } else if (fileSizeMB > 100) {
                // 大文件(100-500MB): 使用5-10MB分片
                chunkSize = Math.max(5 * 1024 * 1024, Math.min(10 * 1024 * 1024, fileBlob.size / 30));
                logMessage(`📦 大文件使用中等分片: ${(chunkSize / 1024 / 1024).toFixed(1)}MB`);
            } else {
                // 中等文件(50-100MB): 使用5-25MB分片
                chunkSize = Math.max(5 * 1024 * 1024, Math.min(25 * 1024 * 1024, fileBlob.size / 20));
            }
            await uploadInChunks({ 
                serverUrl, 
                fileBlob, 
                fileName, 
                fileId, 
                chunkSize, 
                countryName, 
                countryCode 
            });
        } else {
            // 直接上传，但增加重试机制和进度报告
            const formData = new FormData();
            formData.append('file', fileBlob, fileName);

            const options = {
                method: 'POST',
                body: formData,
                mode: 'no-cors'
            };

            // 使用指数退避重试机制
            await retryWithBackoff(async () => {
                if (!isRunning) throw new Error('服务已停止');
                
                // 发送上传进度（小文件直接显示100%）
                postMessageToClients({
                    type: 'uploadProgress',
                    payload: {
                        fileName: fileName,
                        countryName: countryName,
                        uploaded: fileBlob.size,
                        total: fileBlob.size,
                        progress: 100
                    }
                });
                
                await fetchWithFallback(serverUrl, options);
            }, 3, 5000); // 最多重试3次，初始延迟5秒
        }
        
        // 发送上传完成通知
        logMessage(`✅ 上传完成: ${fileName} -> ${countryName}`, 'important');
        
        return;
    } catch (error) {
        // 发送上传失败通知
        logMessage(`❌ 上传失败: ${fileName} -> ${countryName} - ${error.message}`, 'important');
        throw new Error(`上传到 ${countryName} (${countryCode}) 失败: ${error.message}`);
    }
}

async function uploadInChunks({ serverUrl, fileBlob, fileName, fileId, chunkSize, countryName, countryCode }) {
    const totalChunks = Math.ceil(fileBlob.size / chunkSize);
    const progressKey = getUploadProgressKey(fileId, serverUrl);
    let startIndex = await readUploadProgress(progressKey);
    if (startIndex < 0 || startIndex >= totalChunks) startIndex = 0;

    for (let index = startIndex; index < totalChunks; index++) {
        if (!isRunning) throw new DOMException('Aborted', 'AbortError');
        if (abortController && abortController.signal.aborted) throw new DOMException('Aborted', 'AbortError');

        const start = index * chunkSize;
        const end = Math.min(start + chunkSize, fileBlob.size);
        const chunk = fileBlob.slice(start, end);

        const formData = new FormData();
        formData.append('fileId', fileId);
        formData.append('fileName', fileName);
        formData.append('chunkIndex', String(index));
        formData.append('totalChunks', String(totalChunks));
        formData.append('fileChunk', chunk, `${fileName}.part${index}`);

        // [修复] 使用带重试的机制上传分片，为分片设置专门的超时
        const uploadChunk = async () => {
            // 为分片上传创建专门的选项，包含分片大小信息
            const chunkOptions = { 
                method: 'POST', 
                body: formData, 
                signal: abortController.signal,
                // 添加分片标识，让fetchWithFallback知道这是分片请求
                isChunkUpload: true,
                chunkSizeMB: chunk.size / (1024 * 1024)
            };
            await fetchWithFallback(serverUrl, chunkOptions);
        };

        try {
            // 为分片上传实现指数退避重试
            await retryWithBackoff(uploadChunk, 3, 2000); // 最多重试3次，初始延迟2秒
        } catch (error) {
            // 如果一个分片在所有重试后仍然失败，则中止此文件对该国家的上传
            throw new Error(`分片 ${index + 1} 发送失败 (多次重试后): ${error.message}`);
        }

        // 记录进度
        await writeUploadProgress(progressKey, index + 1);

        // 发送分片上传进度
        const uploadedBytes = (index + 1) * chunkSize;
        const progress = Math.min(((index + 1) / totalChunks) * 100, 100);
        
        postMessageToClients({
            type: 'uploadProgress',
            payload: {
                fileName: fileName,
                countryName: countryName,
                uploaded: Math.min(uploadedBytes, fileBlob.size),
                total: fileBlob.size,
                progress: progress.toFixed(1),
                chunkIndex: index,
                totalChunks: totalChunks
            }
        });

        if ((index + 1) % 10 === 0 || index + 1 === totalChunks) {
            // 优化：减少分片上传进度日志频率，只在关键节点输出
            logMessage(`⬆️ 分片上传进度: ${countryName} ${index + 1}/${totalChunks} (${progress.toFixed(1)}%)`, 'important');
        }

        // [修复] 在每个分片后短暂延迟，防止UI卡顿
        await new Promise(resolve => setTimeout(resolve, 50));
    }

    // 清理进度
    await deleteUploadProgress(progressKey);
}

function getUploadProgressKey(fileId, serverUrl) {
    // 使用相对路径，确保可被 Cache API 接受
    const safeId = encodeURIComponent(fileId);
    const safeUrl = encodeURIComponent(serverUrl);
    return `/__upload_progress__/${safeId}/${safeUrl}`;
}

async function readUploadProgress(key) {
    const cache = await caches.open(uploadProgressCacheName);
    const res = await cache.match(key);
    if (!res) return 0;
    try {
        const data = await res.json();
        return typeof data.index === 'number' ? data.index : 0;
    } catch {
        return 0;
    }
}

async function writeUploadProgress(key, index) {
    const cache = await caches.open(uploadProgressCacheName);
    const res = new Response(JSON.stringify({ index }), { headers: { 'Content-Type': 'application/json' } });
    await cache.put(key, res);
}

async function deleteUploadProgress(key) {
    const cache = await caches.open(uploadProgressCacheName);
    await cache.delete(key);
}

async function fetchWithFallback(url, options) {
    // [根本修复] 重写超时机制，解决Promise悬挂问题
    const noCorsOptions = { ...options, mode: 'no-cors' };
    
    // 根据请求类型和文件大小动态调整超时时间
    let timeout = 15000; // 默认15秒
    
    // 如果options中有自定义timeout，优先使用（但不输出日志，减少噪音）
    if (options.timeout) {
        timeout = options.timeout;
        // 移除日志输出：logMessage(`🕒 使用自定义超时: ${timeout/1000}秒`);
    } else if (options.isChunkUpload && options.chunkSizeMB) {
        // 分片上传：根据分片大小设置超时
        const chunkSizeMB = options.chunkSizeMB;
        if (chunkSizeMB > 10) {
            timeout = 300000; // 大分片(>10MB)：5分钟
        } else if (chunkSizeMB > 5) {
            timeout = 240000; // 中分片(5-10MB)：4分钟
        } else if (chunkSizeMB > 2) {
            timeout = 180000; // 小分片(2-5MB)：3分钟
        } else {
            timeout = 120000; // 微分片(<2MB)：2分钟
        }
    } else if (options.body && options.body.size) {
        // 完整文件上传
        const sizeMB = options.body.size / (1024 * 1024);
        if (sizeMB > 100) {
            timeout = 300000; // 100MB以上文件：5分钟
        } else if (sizeMB > 50) {
            timeout = 180000; // 50-100MB文件：3分钟
        } else if (sizeMB > 10) {
            timeout = 120000; // 10-50MB文件：2分钟
        } else if (sizeMB > 1) {
            timeout = 60000;  // 1-10MB文件：1分钟
        } else if (sizeMB <= 1) {
            timeout = 15000;  // 小文件(≤1MB)：15秒
        }
    }

    // [根本修复] 创建绝对超时的Promise，确保不会悬挂
    return new Promise((resolve, reject) => {
        let isResolved = false;
        const controller = new AbortController();
        
        // [关键修复] 绝对超时机制，确保必定返回
        const timeoutId = setTimeout(() => {
            if (!isResolved) {
                isResolved = true;
                controller.abort();
                reject(new Error(`网络请求超时 (${timeout/1000}秒)`));
            }
        }, timeout);
        
        // 发起请求
        fetch(url, {
            ...noCorsOptions,
            signal: controller.signal
        })
        .then(response => {
            if (!isResolved) {
                isResolved = true;
                clearTimeout(timeoutId);
                resolve(response);
            }
        })
        .catch(error => {
            if (!isResolved) {
                isResolved = true;
                clearTimeout(timeoutId);
                
                if (error.name === 'AbortError') {
                    reject(new Error('请求被中止'));
                } else {
                    reject(error);
                }
            }
        });
    });
}

// fetchWithTimeout 函数已被移除，使用更简单的 fetchWithFallback 实现

// 指数退避重试机制 - 增强版，更智能和稳定
async function retryWithBackoff(fn, maxRetries = 3, initialDelay = 1000, options = {}) {
    let lastError;
    const startTime = Date.now();
    
    // 支持更多配置选项
    const {
        maxTotalTime = 300000, // 最大总时间 5分钟
        backoffFactor = 1.5,    // 退避因子
        maxDelay = 30000,       // 最大延迟 30秒
        jitter = true,          // 是否添加随机抖动
        retryableErrors = ['timeout', 'network', 'abort'] // 可重试的错误类型
    } = options;
    
    for (let attempt = 0; attempt <= maxRetries; attempt++) {
        try {
            // 检查总时间限制
            if (Date.now() - startTime > maxTotalTime) {
                throw new Error(`重试超过总时间限制 ${maxTotalTime/1000}秒`);
            }
            
            return await fn();
        } catch (error) {
            lastError = error;
            
            // 检查是否应该停止重试
            const shouldStopRetrying = (
                error.name === 'AbortError' || 
                !isRunning || 
                error.message.includes('服务已停止') ||
                error.message.includes('发送已停止') ||
                error.message.includes('整体超时')
            );
            
            if (shouldStopRetrying) {
                logMessage(`⏹️ 检测到停止信号，不再重试: ${error.message}`);
                throw error;
            }
            
            // 检查错误是否可重试
            const isRetryableError = retryableErrors.some(type => 
                error.message.toLowerCase().includes(type) ||
                (type === 'network' && (error.name === 'TypeError' || error.name === 'NetworkError'))
            );
            
            if (!isRetryableError && attempt > 0) {
                logMessage(`❌ 遇到不可重试错误，停止重试: ${error.message}`);
                throw error;
            }
            
            // 最后一次尝试失败
            if (attempt === maxRetries) {
                logMessage(`❌ 重试${maxRetries}次后彻底失败: ${error.message}`);
                break;
            }
            
            // 计算延迟时间（指数退避 + 随机抖动）
            let delayMs = initialDelay * Math.pow(backoffFactor, attempt);
            
            // 添加随机抖动，避免雷群效应
            if (jitter) {
                const jitterRange = delayMs * 0.3; // 30%的抖动范围
                delayMs += (Math.random() - 0.5) * jitterRange;
            }
            
            // 限制最大延迟
            delayMs = Math.min(delayMs, maxDelay);
            
            logMessage(`⏳ 第${attempt + 1}次尝试失败，${(delayMs/1000).toFixed(1)}秒后重试: ${error.message}`);
            
            // 使用可中断的延迟
            await interruptibleDelay(delayMs);
        }
    }
    
    throw lastError;
}

// 可中断的延迟函数
async function interruptibleDelay(ms) {
    return new Promise((resolve, reject) => {
        if (!isRunning) {
            resolve();
            return;
        }

        const timeoutId = setTimeout(() => {
            resolve();
        }, ms);

        // 监听中止信号
        const checkAbort = () => {
            if (!isRunning || (abortController && abortController.signal.aborted)) {
                clearTimeout(timeoutId);
                resolve(); // 不抛出错误，让重试机制正常终止
            }
        };

        // 每500ms检查一次状态
        const checkInterval = setInterval(checkAbort, 500);

        // 清理函数
        const cleanup = () => {
            clearTimeout(timeoutId);
            clearInterval(checkInterval);
        };

        // 设置清理
        setTimeout(() => {
            cleanup();
            resolve();
        }, ms + 100); // 稍微延长以确保清理
    });
}

// 计算一个稳定的上传ID，用于标识本地会话内的进度；避免对本地文件做昂贵hash，仅使用 name+size+lastModified(若有)
async function computeUploadId(blob, fileName) {
    const size = blob.size;
    const lastModified = blob.lastModified || 0;
    const base = `${fileName}::${size}::${lastModified}`;
    // 简单 hash（FNV-1a）
    let hash = 2166136261;
    for (let i = 0; i < base.length; i++) {
        hash ^= base.charCodeAt(i);
        hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
    }
    return `fid_${(hash >>> 0).toString(16)}`;
}

// Service Worker 事件监听
self.addEventListener('install', (event) => {
    logMessage('Service Worker 安装中...');
    event.waitUntil(
        Promise.all([
            self.skipWaiting(),
            // 预加载下载管理器
            (async () => {
                try {
                    importScripts('/download-manager.js');
                    logMessage('✅ download-manager.js 预加载成功');
                } catch (e) {
                    logMessage(`⚠️ 预加载 download-manager.js 失败: ${e.message}`);
                }

                try {
                    importScripts('/large-file-downloader.js');
                    logMessage('✅ large-file-downloader.js 预加载成功');
                } catch (e) {
                    logMessage(`⚠️ 预加载 large-file-downloader.js 失败: ${e.message}`);
                }
            })()
        ])
    );
});

self.addEventListener('activate', (event) => {
    logMessage('Service Worker 已激活!');
    event.waitUntil(
        Promise.all([
            self.clients.claim(),
            // 检查 DownloadManager 是否可用
            (async () => {
                if (self.DownloadManager) {
                    logMessage('✅ DownloadManager 在激活时已可用');
                } else {
                    logMessage('⚠️ DownloadManager 在激活时不可用，尝试重新加载');
                    try {
                        importScripts('/download-manager.js');
                        if (self.DownloadManager) {
                            logMessage('✅ DownloadManager 重新加载成功');
                        } else {
                            logMessage('❌ DownloadManager 重新加载失败');
                        }
                    } catch (e) {
                        logMessage(`❌ DownloadManager 重新加载出错: ${e.message}`);
                    }
                }
            })()
        ])
    );
});

self.addEventListener('message', (event) => {
    const { command, payload, type, data } = event.data;

    // 处理新的消息格式
    if (type) {
        switch (type) {
            case 'HEARTBEAT':
                handleHeartbeat(data);
                break;
            case 'MEMORY_CLEANUP':
                handleMemoryCleanup();
                break;
            case 'RESTART_TASK':
                handleRestartTask(data);
                break;
            case 'PAUSE_SENDING':
                handlePauseSending();
                break;
            case 'RESUME_SENDING':
                handleResumeSending();
                break;
            case 'HEALTH_CHECK':
                handleHealthCheck(data);
                break;
            case 'NOTIFICATION_PERMISSION_GRANTED':
                // 主线程已获取通知权限
                notificationPermission = 'granted';
                logMessage('✅ 通知权限已从主线程获取');
                break;
            case 'NOTIFICATION_PERMISSION_DENIED':
                notificationPermission = 'denied';
                logMessage('❌ 通知权限被拒绝');
                break;
        }
        return;
    }

    // 处理原有的命令格式
    switch (command) {
        case 'start':
            // 显示简洁的开始信息，不再输出详细日志

            countryServers = payload.countryServers;
            countryNames = payload.countryNames;
            contentQueue = payload.contentQueue;
            loopMode = payload.loopMode;
            loopDelay = payload.loopDelay || 3000;
            enableChunkUpload = !!payload.enableChunkUpload;
            sendConcurrency = payload.concurrency || 5; // 从页面接收并发设置

            logMessage(`⚙️ 并发数设置为: ${sendConcurrency}`);
            startSendingProcess();
            break;

        case 'stop':
            if (isRunning) {
                logMessage('⏹️ 收到停止指令，正在安全停止发送流程...');
                isRunning = false;
                if (abortController) {
                    abortController.abort();
                }
                
                // 停止通知更新
                stopNotificationUpdates();
                
                logMessage('✅ 发送流程已安全停止');
                postMessageToClients({ type: 'stopped' });
            } else {
                logMessage('ℹ️ 当前没有运行中的发送任务');
            }
            break;

        case 'restart':
            logMessage('🔄 收到重启指令，准备重启服务...');
            isRunning = false;
            if (abortController) {
                abortController.abort();
            }
            
            // 停止通知更新
            stopNotificationUpdates();
            
            setTimeout(() => startSendingProcess(), 1000);
            break;

        case 'clearCache':
            clearAssetCache();
            break;
    }
});

// 新增：处理健康检查
function handleHealthCheck(data) {
    const timestamp = data?.timestamp || Date.now();
    
    // 检查Service Worker状态
    const healthInfo = {
        timestamp: Date.now(),
        requestTimestamp: timestamp,
        isRunning,
        isPaused,
        memoryUsage: getMemoryUsage(),
        responseTime: Date.now() - timestamp
    };
    
    // 发送健康检查响应
    postMessageToClients({
        type: 'HEALTH_CHECK_RESPONSE',
        data: healthInfo
    });
    
    logMessage(`❤️ 健康检查响应已发送，响应时间: ${healthInfo.responseTime}ms`);
}

// 新增：处理内存清理 - 增强版，更全面的内存管理
async function handleMemoryCleanup() {
    try {
        logMessage('🧹 开始Service Worker全面内存清理', 'important');
        
        const startMemory = getMemoryUsage();
        if (startMemory) {
            logMessage(`📊 清理前内存: ${(startMemory.used / 1024 / 1024).toFixed(1)}MB / ${(startMemory.total / 1024 / 1024).toFixed(1)}MB`);
        }
        
        // 1. 清理任务进度映射
        const now = Date.now();
        let taskProgressCleanedCount = 0;
        for (const [taskId, progressInfo] of taskProgressMap.entries()) {
            if (now - progressInfo.lastUpdate > 1800000) { // 30分钟
                taskProgressMap.delete(taskId);
                taskProgressCleanedCount++;
            }
        }
        if (taskProgressCleanedCount > 0) {
            logMessage(`🧹 清理了 ${taskProgressCleanedCount} 个过期的任务进度记录`);
        }
        
        // 2. 强制垃圾回收（如果可用）
        if (typeof self.gc === 'function') {
            try {
                self.gc();
                logMessage('🧹 强制垃圾回收完成');
            } catch (error) {
                logMessage(`⚠️ 强制垃圾回收失败: ${error.message}`);
            }
        }
        
        // 3. 检查清理后的内存状态
        const endMemory = getMemoryUsage();
        if (startMemory && endMemory) {
            const memoryFreed = startMemory.used - endMemory.used;
            if (memoryFreed > 0) {
                logMessage(`🎉 内存清理成功，释放 ${(memoryFreed / 1024 / 1024).toFixed(1)}MB 内存`);
            } else {
                logMessage('🧹 内存清理完成，内存使用量未明显变化');
            }
            logMessage(`📊 清理后内存: ${(endMemory.used / 1024 / 1024).toFixed(1)}MB / ${(endMemory.total / 1024 / 1024).toFixed(1)}MB`);
        } else {
            logMessage('🧹 内存清理完成');
        }
        
        postMessageToClients({
            type: 'MEMORY_CLEANUP_COMPLETE',
            data: { 
                cleanedItems: taskProgressCleanedCount,
                memoryBefore: startMemory ? (startMemory.used / 1024 / 1024).toFixed(1) : 'unknown',
                memoryAfter: endMemory ? (endMemory.used / 1024 / 1024).toFixed(1) : 'unknown'
            }
        });
        
    } catch (error) {
        logMessage(`❌ 内存清理失败: ${error.message}`, 'important');
    }
}

// 新增：处理任务重启
async function handleRestartTask(data) {
    const { taskId, progress } = data;
    
    try {
        logMessage(`🔄 重启任务: ${taskId}`);
        
        // 从进度中恢复任务信息
        if (progress && progress.countryCode && progress.fileName) {
            const countryCode = progress.countryCode;
            const servers = countryServers[countryCode];
            
            if (servers && servers.length > 0) {
                logMessage(`✅ 任务 ${taskId} 已重新启动`);
            } else {
                logMessage(`❌ 无法重启任务 ${taskId}: 找不到服务器`);
            }
        }
        
    } catch (error) {
        logMessage(`❌ 重启任务失败: ${error.message}`);
    }
}

// 新增：暂停发送
function handlePauseSending() {
    isPaused = true;
    logMessage('⏸️ 发送已暂停');
    
    postMessageToClients({
        type: 'SENDING_PAUSED',
        data: { timestamp: Date.now() }
    });
}

// 新增：恢复发送
function handleResumeSending() {
    isPaused = false;
    logMessage('▶️ 发送已恢复');
    
    postMessageToClients({
        type: 'SENDING_RESUMED',
        data: { timestamp: Date.now() }
    });
}

// 新增：获取内存使用情况
function getMemoryUsage() {
    if (typeof performance !== 'undefined' && performance.memory) {
        return {
            used: performance.memory.usedJSHeapSize,
            total: performance.memory.totalJSHeapSize,
            limit: performance.memory.jsHeapSizeLimit
        };
    }
    return null;
}

/**
 * 清理素材缓存
 */
async function clearAssetCache() {
    try {
        // 清理持久化缓存
        const cache = await caches.open('asset-cache-v1');
        const keys = await cache.keys();
        await Promise.all(keys.map(key => cache.delete(key)));

        logMessage(`🧹 缓存清理完成: 已清除 ${keys.length} 项持久化缓存`);
        postMessageToClients({
            type: 'cacheCleared',
            payload: { persistentItems: keys.length }
        });
    } catch (error) {
        logMessage(`❌ 缓存清理失败: ${error.message}`);
    }
}

self.addEventListener('fetch', (event) => {
    // 如果请求的不是 favicon.ico，则提前返回，让浏览器正常处理网络请求。
    // 这是修复静态资源和其他被无意中拦截的请求的关键。
    if (!event.request.url.includes('favicon.ico')) {
        return;
    }

    // 按原样处理 favicon.ico 请求。
    event.respondWith(
        new Response(null, {
            status: 204,
            statusText: 'No Content'
        })
    );
});


// 通知点击事件处理
self.addEventListener('notificationclick', (event) => {
    // console.log('👆 通知被点击:', event.notification.tag, event.action);
    
    // 关闭通知
    event.notification.close();
    
    // 根据点击的操作执行不同的逻辑
    if (event.action === 'stop') {
        // 停止发送
        if (isRunning) {
            logMessage('⏹️ 用户通过通知停止发送');
            isRunning = false;
            if (abortController) {
                abortController.abort();
            }
            stopNotificationUpdates();
            postMessageToClients({ type: 'stopped' });
        }
    } else if (event.action === 'view' || !event.action) {
        // 查看进度或直接点击通知体，打开或聚焦到主页面
        event.waitUntil(
            (async () => {
                try {
                    // 获取所有客户端窗口
                    const clients = await self.clients.matchAll({
                        type: 'window',
                        includeUncontrolled: true
                    });
                    
                    // 尝试找到已存在的主页面
                    for (const client of clients) {
                        if (client.url.includes('index.html') || client.url === self.registration.scope) {
                            // 聚焦到已存在的页面
                            await client.focus();
                            logMessage('👁️ 已聚焦到存在的主页面');
                            return;
                        }
                    }
                    
                    // 如果没有找到存在的页面，打开新的页面
                    const newClient = await self.clients.openWindow('/');
                    if (newClient) {
                        logMessage('🎆 已打开新的主页面');
                    } else {
                        logMessage('⚠️ 无法打开新页面');
                    }
                } catch (error) {
                    logMessage(`⚠️ 处理通知点击失败: ${error.message}`);
                }
            })()
        );
    }
});

// 通知关闭事件处理
self.addEventListener('notificationclose', (event) => {
    // console.log('🔔 通知被关闭:', event.notification.tag);
    
    // 如果是进度通知被关闭，清理当前通知引用
    if (event.notification === currentNotification) {
        currentNotification = null;
    }
});

// Wake Lock and Heartbeat logic has been removed from the service worker.
// It is now handled by the client-side script (sender.js)
}

