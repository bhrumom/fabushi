            // 更新循环状态显示
            const cycleInfo = document.createElement('div');
            cycleInfo.className = 'progress-info cycle-complete';
            cycleInfo.style.cssText = 'font-size: 13px; color: #28a745; margin-top: 5px; padding: 5px 10px; background: #d4edda; border-radius: 4px; border-left: 3px solid #28a745; font-weight: bold;';
            cycleInfo.innerHTML = `🔄 第 ${cycle} 轮完成，${nextCycleIn}秒后开始下一轮`;
            
            // 移除旧的循环信息
            const oldCycleInfo = this.sentDataEl.querySelector('.cycle-complete');
            if (oldCycleInfo) {
