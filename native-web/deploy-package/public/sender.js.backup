// 全球法布施控制器 - v3.1 (支持拖拽排序和删除)
class GlobalDharmaSender {
    constructor() {
        // 单例模式：防止重复初始化导致事件重复绑定
        if (window.globalDharmaSenderInstance) {
            console.warn("GlobalDharmaSender 已被实例化，将返回现有实例。");
            return window.globalDharmaSenderInstance;
        }
        window.globalDharmaSenderInstance = this;

        this.isRunning = false;
        this.fileQueue = []; // 统一管理所有待发送项
        this.sortable = null; // SortableJS 实例
        
        // 修复：更准确的状态跟踪变量
        this.totalItemsToSend = 0;
        this.totalFiles = 0;
        this.totalCountries = 0;
        this.completedFiles = 0;
        this.completedTasks = 0;
        this.currentFile = '';
        this.currentCycle = 1;
        this.isLoopMode = false;
        this.hasError = false;
        
        this.startTime = 0;
        this.progressTimer = null; // 循环模式下的进度条动画定时器
        this.wakeLock = null; // 屏幕常亮锁
        this.isTogglingAssets = false; // 用于 toggleBuiltInAssets 防抖
        this.useFallback = false; // 新增：降级模式标志

        // 修复：循环模式下的累计计数
        this.grandTotalCompletedFiles = 0;
        this.grandTotalCompletedTasks = 0;
        this.lastCycleHandledForTotal = 0;

        // 日志优化：只在控制台输出，不显示在界面上
        
        // 状态更新优化：减少频繁的DOM操作
        this.lastStatsUpdate = 0;
        this.statsUpdateInterval = 1000; // 最小更新间隔 1 秒
        this.lastProgressPercentage = 0;
        this.lastStatusText = '';
        this.isStatsUpdateScheduled = false;
        
        // 进度日志控制：避免过于频繁的日志输出
        this.lastProgressLogTime = 0;
        this.progressLogInterval = 5000; // 每5秒最多记录一次进度日志

        // 从全局对象获取国家和服务器信息 (修复：创建副本以防外部修改)
        this.countries = window.globalCountryServers ? [...window.globalCountryServers.getAllCountries()] : [];
        this.countryServers = window.globalCountryServers ? window.globalCountryServers.servers : {};
        this.countryNames = window.globalCountryServers ? window.globalCountryServers.countryNames : {};
        this.assetTreeData = window.dharmaAssets || {};
        
        // 添加调试信息
        console.log('🌳 法宝树数据初始化:', {
            hasData: !!window.dharmaAssets,
            categories: Object.keys(this.assetTreeData).length,
            categoryNames: Object.keys(this.assetTreeData)
        });

        // 国家发送状态跟踪
        this.countryStatus = new Map(); // 存储每个国家的发送状态
        this.countryStatsEl = null; // 国家统计显示元素
        this.countryUpdateQueue = new Set();
        this.isCountryUpdateScheduled = false;

        // 速度控制元素
        // this.speedSlider = document.getElementById('speedSlider'); // 已移除：并发设置
        // this.speedValue = document.getElementById('speedValue'); // 已移除：并发设置

        this.initElements();
        this.bindEvents();
        this.updateGlobalStatsUI();
    }
    
    // 新增：控制进度日志输出频率的方法
    shouldLogProgress() {
        const now = Date.now();
        if (now - this.lastProgressLogTime >= this.progressLogInterval) {
            this.lastProgressLogTime = now;
            return true;
        }
        return false;
    }

    initElements() {
        this.fileInput = document.getElementById('fileInput');
        this.fileListEl = document.getElementById('fileList');
        this.builtInAssetsBtn = document.getElementById('builtInAssetsBtn');
        this.builtInAssetsContainer = document.getElementById('builtInAssetsContainer');
        this.assetSearchEl = document.getElementById('assetSearch');
        this.assetTreeEl = document.getElementById('assetTree');
        this.startBtn = document.getElementById('startBtn');
        this.stopBtn = document.getElementById('stopBtn');
        this.loopMode = document.getElementById('loopMode');
        this.countryCountEl = document.getElementById('countryCount');
        this.sentCountEl = document.getElementById('sentCount');
        this.sentDataEl = document.getElementById('sentData'); // 重用为显示进度
        // this.sendSpeedEl = document.getElementById('sendSpeed'); // 已移除：并发设置 // 将被隐藏
        this.progressBar = document.getElementById('progressBar');
        // 国家状态相关元素
        this.countryStatsContainer = document.getElementById('countryStatsContainer');
        this.countryStatsEl = document.getElementById('countryStats');
        // 速度控制元素
        // this.speedSlider = document.getElementById('speedSlider');
        // this.speedValue = document.getElementById('speedValue');
    }

    bindEvents() {
        this.fileInput.addEventListener('change', (e) => this.handleFileSelect(e));
        this.builtInAssetsBtn.addEventListener('click', () => this.toggleBuiltInAssets());
        this.assetSearchEl.addEventListener('input', (e) => this.renderAssetTree(this.assetTreeData, e.target.value));
        this.assetTreeEl.addEventListener('click', (e) => this.handleAssetTreeClick(e));
        this.fileListEl.addEventListener('click', (e) => this.handleFileListItemClick(e));
        this.startBtn.addEventListener('click', (e) => { e.preventDefault(); this.startSending(); });
        this.stopBtn.addEventListener('click', (e) => { e.preventDefault(); this.stopSending(); });
        // 速度控制事件监听
        // this.speedSlider.addEventListener('input', (e) => this.updateSpeedValue(e.target.value)); // 已移除：并发设置

        this.registerServiceWorker();
    }

    registerServiceWorker() {
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                // Service Worker registration - let the browser handle updates
                navigator.serviceWorker.register('/service-worker.js')
                    .then(registration => {
                        console.log('Service Worker 注册成功: ', registration);
                        this.logMessage('✅ 后台服务已准备就绪。');
                        
                        // 监听来自 Service Worker 的消息
                        navigator.serviceWorker.addEventListener('message', event => {
                            this.handleWorkerMessage(event);
                        });
                        
                        // 初始化通知权限检查
                        this.checkNotificationPermission();
                    })
                    .catch(error => {
                        console.error('Service Worker 注册失败: ', error);
                        this.logMessage('❌ 无法启动后台服务，将自动降级到前台发送模式。');
                        this.logMessage('⚠️ 前台模式下，关闭或切换页面将中断发送。');
                        this.useFallback = true;
                    });
            });
        } else {
            this.logMessage('❌ 您的浏览器不支持 Service Worker，已自动降级到前台发送模式。');
            this.logMessage('⚠️ 前台模式下，关闭或切换页面将中断发送。');
            this.useFallback = true;
        }
    }

    // 新增：检查通知权限
    checkNotificationPermission() {
        if (!('Notification' in window)) {
            console.log('⚠️ 此浏览器不支持通知功能');
            return;
        }

        const permission = Notification.permission;
        console.log('🔔 当前通知权限状态:', permission);
        
        // 通知Service Worker当前权限状态
        if (navigator.serviceWorker && navigator.serviceWorker.controller) {
            const messageType = permission === 'granted' ? 
                'NOTIFICATION_PERMISSION_GRANTED' : 
                'NOTIFICATION_PERMISSION_DENIED';
            
            navigator.serviceWorker.controller.postMessage({
                type: messageType
            });
        }
        
        if (permission === 'granted') {
            this.logMessage('✅ 锁屏通知已启用，您可以在通知栏查看发送进度');
        } else if (permission === 'denied') {
            this.logMessage('⚠️ 通知权限被拒绝，无法在锁屏时显示进度');
        }
    }

    updateGlobalStatsUI() {
        this.countryCountEl.textContent = this.countries.length;
        // 初始化速度显示
        // if (this.speedValue) { // 已移除：并发设置
        //     this.speedValue.textContent = this.speedSlider.value; // 已移除：并发设置
        // }
    }

    updateSpeedValue(value) {
        if (this.speedValue) {
            this.speedValue.textContent = value;
        }
    }

    handleFileSelect(event) {
        const newFiles = Array.from(event.target.files);
        newFiles.forEach(file => {
            // 避免重复添加
            if (!this.fileQueue.some(item => item.type === 'file' && item.file.name === file.name)) {
                this.fileQueue.push({
                    type: 'file',
                    id: `file_${file.name}_${file.lastModified}`, // 创建一个更唯一的ID
                    name: file.name,
                    file: file
                });
            }
        });
        this.updateFileListUI();
    }

    toggleBuiltInAssets() {
        // 防抖：防止因重复调用导致的状态错乱
        if (this.isTogglingAssets) {
            return;
        }
        this.isTogglingAssets = true;
        setTimeout(() => { this.isTogglingAssets = false; }, 100); // 100毫秒的冷却时间

        // 终极修复：使用 window.getComputedStyle 来准确判断元素的当前显示状态
        const isVisible = window.getComputedStyle(this.builtInAssetsContainer).display !== 'none';
        
        if (isVisible) {
            // 如果可见，则隐藏
            this.builtInAssetsContainer.style.display = 'none';
            this.builtInAssetsBtn.textContent = '🎨 选取内置法宝';
        } else {
            // 如果隐藏，则显示并渲染内容
            this.builtInAssetsContainer.style.display = 'block';
            this.builtInAssetsBtn.textContent = '📁 隐藏法宝';
            this.logMessage('🌳 正在加载内置法宝树...');
            this.renderAssetTree(this.assetTreeData);
            
            // 添加调试信息
            setTimeout(() => {
                const folderItems = this.assetTreeEl.querySelectorAll('.folder-item');
                const folderNames = this.assetTreeEl.querySelectorAll('.folder-name');
                console.log(`法宝树加载完成: 找到 ${folderItems.length} 个文件夹项, ${folderNames.length} 个文件夹名称`);
                this.logMessage(`✅ 法宝树加载完成，共 ${folderItems.length} 个文件夹可展开`);
            }, 100);
        }
    }


    renderAssetTree(node, searchTerm = '', currentPath = '') {
        const term = searchTerm.trim().toLowerCase();
        const isR2File = (fileInfo) => {
            // 检查文件是否为R2资源：如果是对象且有path属性，则为R2资源
            return typeof fileInfo === 'object' && fileInfo.path;
        };
        const isR2Node = (key) => {
            // 检查节点是否包含R2资源
            const nodeData = node[key];
            return nodeData && nodeData._files && nodeData._files.some(file => isR2File(file));
        };

        const generateFileListItem = (fileInfo, path) => {
            const isR2 = isR2File(fileInfo);
            const icon = isR2 ? '☁️' : '📄';
            // R2 文件是对象 {name, path}, 本地文件是字符串
            const fileName = typeof fileInfo === 'object' ? fileInfo.name : fileInfo;
            const filePath = typeof fileInfo === 'object' ? fileInfo.path : (path ? `${path}/${fileInfo}` : fileInfo);
            const itemType = isR2 ? 'r2-asset' : 'asset';
            
            const isSelected = this.fileQueue.some(item => item.path === filePath);

            return `
                <li class="file-item ${isSelected ? 'selected' : ''}" data-path="${filePath}" data-name="${fileName}" data-type="${itemType}">
                    ${icon} ${fileName} ${isR2 ? `<span style="color: #999; font-size: 12px;">(云端)</span>` : ''}
                </li>`;
        };

        // 搜索模式：扁平化列表
        if (term) {
            let html = '<ul class="asset-folder">';
            const search = (currentNode, path) => {
                if (currentNode._files) {
                    currentNode._files.forEach(file => {
                        const fileName = typeof file === 'object' ? file.name : file;
                        if (fileName.toLowerCase().includes(term)) {
                            html += generateFileListItem(file, path);
                        }
                    });
                }
                for (const key in currentNode) {
                    if (key !== '_files') {
                        search(currentNode[key], path ? `${path}/${key}` : key);
                    }
                }
            };
            search(node, '');
            html += '</ul>';
            this.assetTreeEl.innerHTML = html;
            return;
        }

        // 默认模式：树状结构
        const generateTreeHtml = (currentNode, path) => {
            let html = '<ul class="asset-folder">';
            // 先渲染文件夹
            for (const key in currentNode) {
                if (key === '_files') continue;
                const newPath = path ? `${path}/${key}` : key;
                const icon = isR2Node(key) ? '☁️' : '';
                const subTreeHtml = generateTreeHtml(currentNode[key], newPath);
                // 修复：确保HTML结构正确，移除icon因为CSS会自动添加
                html += `
                    <li class="folder-item">
                        <span class="folder-name">${icon}${key}</span>
                        ${subTreeHtml}
                    </li>`;
            }
            // 再渲染文件
            if (currentNode._files) {
                currentNode._files.forEach(file => {
                    html += generateFileListItem(file, path);
                });
            }
            html += '</ul>';
            return html;
        };
        this.assetTreeEl.innerHTML = generateTreeHtml(node, currentPath);
    }
    
    handleAssetTreeClick(event) {
        const target = event.target;
        
        // 修复：更准确地检测文件夹名称点击
        const folderName = target.closest('.folder-name');
        if (folderName) {
            event.preventDefault();
            event.stopPropagation();
            const folderItem = folderName.parentElement;
            folderItem.classList.toggle('open');
            
            // 添加调试日志
            const isOpen = folderItem.classList.contains('open');
            console.log(`文件夹 ${folderName.textContent} ${isOpen ? '已展开' : '已收起'}`);
            return;
        }

        const fileItem = target.closest('.file-item[data-path]');
        if (fileItem) {
            const path = fileItem.dataset.path;
            // 传递整个元素以获取所有 data-* 属性
            this.toggleAssetSelection(path, fileItem);
        }
    }
    
    // 在toggleAssetSelection方法中添加认证检查
    
    toggleAssetSelection(path, element) {
    const itemType = element.dataset.type || 'asset'; // 从 data-type 获取类型
    const name = element.dataset.name;
    const id = `${itemType}_${path}`;
    
    element.classList.toggle('selected');
    const existingIndex = this.fileQueue.findIndex(item => item.id === id);
    
        if (existingIndex > -1) {
            // 如果已存在，则移除
            this.fileQueue.splice(existingIndex, 1);
        } else {
            // 如果不存在，则添加
            this.fileQueue.push({
                type: itemType,
                id: id,
                name: name,
                path: path
            });
        }
        this.updateFileListUI();
    }
    
    handleFileListItemClick(event) {
        if (event.target.classList.contains('delete-btn')) {
            const itemEl = event.target.closest('.file-item-draggable');
            const id = itemEl.dataset.id;
            this.removeItemFromQueue(id);
        }
    }

    removeItemFromQueue(id) {
        const index = this.fileQueue.findIndex(item => item.id === id);
        if (index > -1) {
            const item = this.fileQueue[index];
            this.fileQueue.splice(index, 1);

            // 如果是内置或云端素材，需要取消其在素材树中的选中状态
            if (item.type === 'asset' || item.type === 'r2-asset') { 
                const assetEl = this.assetTreeEl.querySelector(`[data-path="${item.path}"]`);
                if (assetEl) {
                    assetEl.classList.remove('selected');
                }
            }
            this.updateFileListUI();
        }
    }

    updateFileListUI() {
        this.fileListEl.innerHTML = ''; // 清空列表

        if (this.fileQueue.length === 0) {
            this.fileListEl.innerHTML = `<div class="file-item" style="text-align: center; color: #999;">尚未选择任何善缘或法宝</div>`;
            return;
        }

        this.fileQueue.forEach(item => {
            const div = document.createElement('div');
            div.className = 'file-item-draggable';
            div.dataset.id = item.id;
            
            // 根据项目类型选择图标
            const icon = item.type === 'r2-asset' ? '☁️' : '📄';
            const sizeInfo = item.type === 'file' ? ` <span style="color: #666; font-size: 12px;">(${this.formatFileSize(item.file.size)})</span>` : '';

            div.innerHTML = `
                <span class="file-item-name">${icon} ${item.name}${sizeInfo}</span>
                <button class="delete-btn" title="删除此项">×</button>
            `;
            this.fileListEl.appendChild(div);
        });

        this.initSortable();
    }
    
    initSortable() {
        if (this.sortable) {
            this.sortable.destroy();
        }
        this.sortable = new Sortable(this.fileListEl, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            onEnd: (evt) => {
                const item = this.fileQueue.splice(evt.oldIndex, 1)[0];
                this.fileQueue.splice(evt.newIndex, 0, item);
                // 无需重新渲染，SortableJS已经处理了DOM
            }
        });
    }

    formatFileSize(bytes) {
        if (bytes < 1024) return `${bytes} B`;
        const i = Math.floor(Math.log(bytes) / Math.log(1024));
        return `${(bytes / Math.pow(1024, i)).toFixed(2)} ${['B', 'KB', 'MB', 'GB'][i]}`;
    }

    // 检查用户会员状态
    async checkMembershipStatus(token) {
        try {
            const response = await fetch('/api/stripe/membership-status', {
                method: 'GET',
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                if (response.status === 401) {
                    throw new Error('认证失败，请重新登录');
                }
                throw new Error(`HTTP ${response.status}: ${response.statusText}`);
            }

            const data = await response.json();
            return data.membership;
        } catch (error) {
            console.error('获取会员状态失败:', error);
            throw error;
        }
    }

    // 简化日志系统，只在控制台输出错误信息
    logMessage(message, level = 'info') {
        // 只输出错误、警告和重要信息
        const isErrorMessage = message.includes('❌') || message.includes('失败') || 
                              message.includes('错误') || message.includes('超时') ||
                              message.includes('异常') || level === 'error';
        
        const isWarningMessage = message.includes('⚠️') || message.includes('警告') ||
                               level === 'warning';
        
        const isImportantMessage = message.includes('🚀') || message.includes('⏹️') ||
                                 message.includes('启动') || message.includes('停止') ||
                                 level === 'important';
        
        // 只在控制台输出错误、警告和重要信息
        if (isErrorMessage || isWarningMessage || isImportantMessage) {
            console.log(message);
        }
    }




    async startSending() {
        this.logMessage('▶️ “开始”按钮点击事件已触发。');
        // 检查用户登录状态
        const token = localStorage.getItem('authToken');
        if (!token) {
            this.logMessage('❌ 请先登录后再使用全球法布施功能。');
            alert('请先登录后再使用全球法布施功能！');
            if (typeof showLoginModal === 'function') {
                showLoginModal();
            }
            return;
        }

        // 检查用户会员状态
        this.logMessage('🔍 正在验证会员权限...');
        try {
            const membershipStatus = await this.checkMembershipStatus(token);
            if (!membershipStatus.isActive) {
                this.logMessage('❌ 全球法布施功能需要会员权限。');
                const upgradeMessage = membershipStatus.type === 'trial' && membershipStatus.isExpired 
                    ? '您的免费试用期已结束，请升级为付费会员以继续使用全球发送功能。'
                    : '全球法布施功能仅限会员使用，请先开通会员服务。';
                
                alert(`🔒 ${upgradeMessage}\n\n点击确定前往会员页面。`);
                
                // 跳转到会员页面
                if (typeof showMembershipModal === 'function') {
                    showMembershipModal();
                } else {
                    window.location.href = '/membership.html';
                }
                return;
            }
            
            this.logMessage(`✅ 会员验证通过 (${membershipStatus.type === 'trial' ? '试用期' : '付费会员'})`);
            if (membershipStatus.daysLeft && membershipStatus.daysLeft <= 7) {
                this.logMessage(`⚠️ 提醒：您的会员服务将在 ${membershipStatus.daysLeft} 天后到期`);
            }
        } catch (error) {
            this.logMessage('❌ 会员状态验证失败，请重新登录或联系客服。');
            console.error('会员状态检查失败:', error);
            alert('会员状态验证失败，请重新登录后重试。');
            return;
        }
        
        if (this.isRunning) {
            this.logMessage('⚠️ 发送任务已在运行中。');
            return;
        }

        // 自动降级判断
        if (this.useFallback || !navigator.serviceWorker || !navigator.serviceWorker.controller) {
            if (this.fileQueue.length === 0) {
                alert('请先选择文件或内置素材');
                this.logMessage('🤷‍♀️ 未选择任何内容，已停止。');
                return;
            }
            
            const confirmMessage = `🙏 全球法布施 (前台模式)\n\n将向全球 ${this.countries.length} 个国家发送 ${this.fileQueue.length} 个内容项。\n\n⚠️ 注意：\n• 当前为前台发送模式，请勿关闭或切换浏览器页面，否则发送将中断。\n\n确定开始吗？`;

            if (confirm(confirmMessage)) {
                if (!this.useFallback) {
                    this.logMessage('⚠️ 后台服务未就绪，临时切换到前台模式。');
                }
                this.startSendingInForeground();
            } else {
                this.logMessage('🤷‍♀️ 用户取消了操作。');
            }
            return;
        }

        if (this.fileQueue.length === 0) {
            alert('请先选择文件或内置素材');
            this.logMessage('🤷‍♀️ 未选择任何内容，已停止。');
            return;
        }

        this.logMessage('🙏 正在准备法布施内容...');
        // 核心改动：不再预读文件，而是直接构建包含 File 对象的队列
        const contentQueue = this.buildContentQueue();
        this.logMessage(`✔️ 内容列表准备完成，共找到 ${contentQueue.length} 个项目。`);

        if (contentQueue.length === 0) {
            this.logMessage('🤷‍♀️ 内容准备失败，或所有选定素材都无法加载。');
            return;
        }

        this.logMessage('🤔 正在弹出确认对话框...');
        
        // 检查是否有大文件并给出特别提醒
        const largeFiles = contentQueue.filter(item => {
            if (item.type === 'file' && item.size > 100 * 1024 * 1024) {
                return true;
            }
            return false;
        });
        
        let confirmMessage = `🙏 全球法布施\n\n将向全球 ${this.countries.length} 个国家发送 ${contentQueue.length} 个内容项。\n\n⚠️ 注意：\n• 所有文件将先下载到本地再发送\n• R2云端资源会单独询问确认\n• 大于25MB的文件会单独询问确认`;
        
        if (largeFiles.length > 0) {
            const largeFileNames = largeFiles.map(f => `${f.name} (${(f.size / 1024 / 1024).toFixed(1)}MB)`).join('\n  ');
            confirmMessage += `\n\n🚨 检测到大文件：\n  ${largeFileNames}\n\n大文件发送需要更长时间，建议：\n• 确保网络连接稳定\n• 避免切换应用或关闭浏览器\n• 耐心等待，系统会自动重试失败的上传`;
        }
        
        confirmMessage += `\n\n确定开始吗？`;
        
        const confirmed = confirm(confirmMessage);
        if (!confirmed) {
            this.logMessage('🤷‍♀️ 用户取消了操作。');
            return;
        }
        this.logMessage('✅ 用户已确认，开始发送流程。');

        this.isRunning = true;
        // 请求屏幕常亮，减少移动端息屏/切后台导致的中断
        this.requestWakeLock();
        this.startBtn.disabled = true;
        this.stopBtn.disabled = false;
        
        // 修复：重置所有状态变量
        this.completedFiles = 0;
        this.completedTasks = 0;
        this.grandTotalCompletedFiles = 0;
        this.grandTotalCompletedTasks = 0;
        this.lastCycleHandledForTotal = 0;
        this.totalFiles = this.fileQueue.length;
        this.totalCountries = this.countries.length;
        this.totalItemsToSend = 0; // 总数将由 worker 初始化
        this.currentFile = '';
        this.currentCycle = 1;
        this.isLoopMode = this.loopMode.checked;
        this.hasError = false;

        // 初始化国家状态跟踪
        this.initCountryStatus();

        // 重置UI
        this.progressBar.style.width = '0%';
        this.sentCountEl.textContent = '0';
        this.sentDataEl.innerHTML = `<div>准备中...</div>`;
        this.sentDataEl.style.color = '';
        
        // 停止之前的动画（如果有）
        this.stopProgressAnimation();
        
        this.logMessage('👷‍♂️ 正在通过后台服务启动发送任务...');

        const payload = {
            countryServers: this.countryServers,
            countryNames: this.countryNames,
            contentQueue: contentQueue,
            loopMode: this.loopMode.checked,
            loopDelay: 3000, // 循环模式下的延迟（修改为3秒）
            enableChunkUpload: true,
            // 修复：传递并发设置
            concurrency: 1 // 已修改：默认单线程模式
        };

        // [修复] 使用 navigator.serviceWorker.ready 确保服务就绪，特别针对Safari等浏览器
        navigator.serviceWorker.ready.then(registration => {
            this.logMessage('✅ 后台服务确认就绪，正在发送启动指令...');
            // 使用 registration.active.postMessage 是更稳妥的方式
            registration.active.postMessage({ command: 'start', payload });
        }).catch(err => {
            this.logMessage(`❌ 等待后台服务就绪时出错: ${err.message}`);
            this.stopSending(); // 停止发送流程
        });
    }

    handleWorkerMessage(event) {
        const { type, payload, message, data } = event.data;
        
        switch (type) {
            case 'started':
                this.logMessage('✅ 后台服务已启动');
                break;
                
            case 'progress':
                this.handleProgressUpdate(payload);
                break;
                
            case 'progress-update':
                // Detailed progress update
                this.completedTasks = payload.completedTasks || this.completedTasks;
                this.updateStats();
                break;
                
            case 'finished':
                this.stopSending(true);
                break;
                
            case 'stopped':
                if (this.isRunning) {
                    this.logMessage('⏹️ 后台服务已停止');
                }
                break;
                
            case 'log':
                this.logMessage(message);
                break;
                
            case 'fileProcessingStart':
                this.handleFileProcessingStart(payload);
                break;
                
            case 'fileProcessingComplete':
                this.handleFileProcessingComplete(payload);
                break;
                
            case 'countryStatus':
                this.handleCountryStatusUpdate(payload);
                break;
                
            case 'country-completed':
                this.handleCountryComplete({
                    countryCode: data.countryCode,
                    fileName: this.currentFile,
                    success: data.success,
                    error: data.error
                }= payload;

        this.countryStatus[country] = 'complete';
        this.updateCountryStatus();
    }handleCycleComplete(payload) {
        const { cycle, completedFiles, totalDispatches }= payload;

        this.logMessage(`✅ 第${cycle}轮完成: ${completedFiles} 个文件，${totalDispatches} 个任务`);
    }handleDelayProgress(payload) {
