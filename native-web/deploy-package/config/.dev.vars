# 此文件用于`wrangler dev`本地开发和测试。
# 它不会被上传到您的生产环境。
# 请在此处填写您的支付宝沙箱凭证。

# 您的支付宝应用ID - 请替换为您在支付宝开放平台创建的应用ID
# 当前使用的密钥对需要与此应用ID匹配
ALIPAY_APP_ID="9021000151631976"

# 您的PKCS#8格式的应用私钥
# 使用您提供的正确应用私钥
ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----

-----END PRIVATE KEY-----"

# 您的支付宝公钥
# 使用您提供的正确支付宝公钥
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----

-----END PUBLIC KEY-----"

# 设置为 "true" 以使用支付宝沙箱环境进行测试
ALIPAY_SANDBOX="true"

# 用于签署JWT令牌的密钥。可以是任何随机字符串。
JWT_SECRET="a_strong_random_secret_for_local_dev"

# Resend 邮件服务的 API Key
RESEND_API_KEY="re_3R2f52su_NawWd24enBd8652Mw4jZzBXW"