name = "auth-worker"
main = "worker.js"
compatibility_date = "2024-01-01"

# 环境变量（敏感信息请使用 wrangler secret put 设置）
[vars]
# FROM_EMAIL = "amitabha@ombhrum.com"  # 建议使用 secret 设置

# 绑定配置
[[kv_namespaces]]
binding = "USERS_KV"
id = "your-kv-namespace-id"
preview_id = "your-preview-kv-namespace-id"

# 静态资源绑定（可选）
[[assets]]
binding = "ASSETS"
bucket = "./public"

# Cloudflare SendEmail 绑定（可选，如果使用 Cloudflare 邮件服务）
# [[email]]
# binding = "EMAIL"
# name = "your-email-binding-name"

# 环境配置
[env.production]
name = "auth-worker-prod"

[env.staging]
name = "auth-worker-staging"

# 开发环境配置
[env.development]
name = "auth-worker-dev"
compatibility_date = "2024-01-01"

# 路由配置（可选）
# routes = [
#   { pattern = "auth.yourdomain.com/*", zone_name = "yourdomain.com" }
# ]

# 自定义域名（可选）
# custom_domains = [
#   { name = "auth.yourdomain.com" }
# ]
