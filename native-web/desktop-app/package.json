{
  "name": "fabushi-desktop",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && electron .\"",
    "react-start": "cd ../deploy-package && npm start",
    "build": "electron-builder",
    "dist": "electron-builder --mac --win --linux",
    "postinstall": "electron-builder install-app-deps",
    "test": "node test.js",
    "lint": "npx eslint .",
    "build-optimized": "node scripts/build-optimized.js"
  },
  "keywords": [
    "buddhism",
    "dharma",
    "global",
    "sending"
  ],
  "author": "Fabushi Team",
  "license": "MIT",
  "description": "全球法布施桌面应用 - 佛教经文发送系统",
  "dependencies": {
    "canvas": "^3.2.0",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^38.0.0",
    "electron-builder": "^24.0.0",
    "wait-on": "^7.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  }
}
